{
  "name": "secab-couplage-expert-v7",
  "version": "7.3.0",
  "private": true,
  "description": "SECAB Couplage Expert - PWA terrain, APK Android et logiciel Windows Electron - formules EDF B13-23.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "desktop": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win nsis portable --publish never",
    "android:init": "npm run build && npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "6.2.0",
    "@capacitor/core": "6.2.0",
    "@vitejs/plugin-react": "4.3.1",
    "vite": "5.4.11",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "6.2.0",
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "fr.secab.couplage.expert",
    "productName": "SECAB Couplage Expert",
    "directories": {
      "output": "release/windows"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}